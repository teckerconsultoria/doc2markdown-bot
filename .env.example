# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Token gerado pelo @BotFather no Telegram
BOT_TOKEN=seu_bot_token_aqui

# Chat IDs autorizados (separe por vírgula para múltiplos usuários)
# Obtenha seu ID enviando qualquer mensagem para @userinfobot
ALLOWED_CHAT_IDS=123456789

# Porta HTTP do keep-alive (Render injeta automaticamente; não altere em produção)
# PORT=8080
